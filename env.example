# SafeEdge — Environment Variables
# Copy to .env and fill in your values

# ── Camera / Location ─────────────────────────────────────────────────────────
CAMERA_ID=CAM_01
BUILDING=Block 4A
FLOOR=1
ZONE=kitchen

# ── Claude Vision (optional — enriches alerts with AI description) ────────────
ANTHROPIC_API_KEY=sk-ant-...
USE_CLAUDE_VISION=true

# ── Communication Layer (teammates fill these in) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
