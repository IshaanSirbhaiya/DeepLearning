# SafeEdge — Environment Variables
# Copy this file to .env and fill in your credentials.
# All keys are OPTIONAL — core detection works without any of them.

# OpenAI API (optional — for Vision 2FA fire confirmation + report narratives)
# Detection still works without it; Vision 2FA will be skipped.
OPENAI_API_KEY=sk-your-key-here

# Telegram Bot (optional — for evacuation alerts to residents)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Supabase (optional — for live dashboard sync)
# Dashboard falls back to mock data if these are missing.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Detection settings (all have sensible defaults)
USE_CLAUDE_VISION=true
CAMERA_ID=CAM_01
